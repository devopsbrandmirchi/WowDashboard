# Supabase – copy to .env and fill in from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (e.g. npm run seed:super-admin) – never expose in Vite/client
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: set to true to skip login and view dashboard without authentication
# VITE_AUTH_BYPASS=true
